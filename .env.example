BETTER_AUTH_SECRET=
# Set in production to your deployed URL (dev infers it from the request)
# BETTER_AUTH_URL=https://your-app.vercel.app
# Local dev uses embedded Postgres automatically; set this to a hosted Postgres
# (e.g. Neon) in production.
# DATABASE_URL=

# Email notifications (optional). Without RESEND_API_KEY, emails are logged to
# the server console instead of being sent.
# RESEND_API_KEY=
# EMAIL_FROM=PB League <noreply@yourdomain.com>
# Absolute base URL used for links in emails (falls back to the request host).
# APP_URL=https://your-app.vercel.app

# Protects the GET /api/cron/auto-confirm endpoint (send as "Bearer <secret>").
# CRON_SECRET=
